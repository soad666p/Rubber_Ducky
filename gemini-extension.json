{
  "name": "rubber-ducky",
  "version": "0.1.0",
  "description": "Workflow Orchestrator MCP",
  "mcpServers": {
    "rubber-ducky": {
      "url": "https://rubber-ducky-7f4txwa74-soad666ps-projects.vercel.app/api/sse",
      "description": "Cloud-hosted Rubber Ducky MCP server."
    },
    "rubber-ducky-local": {
      "command": "node",
      "args": [
        "--loader",
        "ts-node/esm",
        "${extensionPath}/src/server.ts"
